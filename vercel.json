{
    "framework": null,
    "buildCommand": null,
    "outputDirectory": ".",
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
        {
            "source": "/ch1",
            "destination": "/org-portal.html"
        },
        {
            "source": "/ch1-form",
            "destination": "/ch1-edit.html"
        },
        {
            "source": "/ch1-preview",
            "destination": "/ch1-preview.html"
        },
        {
            "source": "/ch1-printable",
            "destination": "/ch1-printable.html"
        },
        {
            "source": "/ch1-individual-pdf",
            "destination": "/ch1-individual-pdf.html"
        },
        {
            "source": "/org-portal",
            "destination": "/org-portal.html"
        },
        {
            "source": "/admin-login",
            "destination": "/admin-login.html"
        },
        {
            "source": "/admin",
            "destination": "/admin.html"
        },
        {
            "source": "/admin-wb-rawdata",
            "destination": "/admin-wb-rawdata.html"
        },
        {
            "source": "/idp-dashboard",
            "destination": "/idp-dashboard/index.html"
        },
        {
            "source": "/idp-dashboard/",
            "destination": "/idp-dashboard/index.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "SAMEORIGIN"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                },
                {
                    "key": "Content-Security-Policy",
                    "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://cdn.sheetjs.com https://cdnjs.cloudflare.com https://cdn.tailwindcss.com https://*.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://fgdommhiqhzvsedfzyrr.supabase.co https://fgdommhiqhzvsedfzyrr.supabase.in wss://fgdommhiqhzvsedfzyrr.supabase.co https://script.google.com https://cdn.jsdelivr.net; img-src 'self' data: blob:; frame-src 'self'; frame-ancestors 'self'; object-src 'none'; base-uri 'self';"
                }
            ]
        },
        {
            "source": "/js/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-cache, no-store, must-revalidate"
                },
                {
                    "key": "Pragma",
                    "value": "no-cache"
                },
                {
                    "key": "Expires",
                    "value": "0"
                }
            ]
        },
        {
            "source": "/css/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, must-revalidate"
                }
            ]
        },
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}