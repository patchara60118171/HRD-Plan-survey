{
  "name": "well-being-survey",
  "version": "3.1.0",
  "description": "Well-being Survey - HRD Chapter 1 Form with enhanced security and performance",
  "scripts": {
    "dev": "npx serve",
    "test:public-survey": "node survey-e2e-runner.js",
    "build": "echo '✅ Static site build completed - no build process required'",
    "deploy": "vercel --prod",
    "deploy:preview": "vercel",
    "lint": "eslint js/ admin/js/",
    "lint:fix": "eslint js/ admin/js/ --fix",
    "format": "prettier --write js/ admin/js/ css/",
    "format:check": "prettier --check js/ admin/js/ css/",
    "test": "node tests/e2e/wellbeing-complete-test.js",
    "sync:questions": "node scripts/wellbeing/validate-schema.js",
    "sync:all": "node scripts/wellbeing/build-report.js",
    "watch:questions": "node scripts/wellbeing/watch-schema.js",
    "supabase:test": "node scripts/supabase-admin.js",
    "supabase:stats": "node -e \"require('./scripts/supabase-admin').getDatabaseStats()\"",
    "supabase:export": "node -e \"require('./scripts/supabase-admin').exportData()\"",
    "sync:google:pending": "node scripts/sync-ch1-google.js pending",
    "sync:google:all": "node scripts/sync-ch1-google.js all",
    "db:status": "node scripts/supabase-admin.js",
    "db:clear-test": "node scripts/clear-ch1-test-data.js",
    "supabase:deploy": "npx supabase functions deploy google-sync --no-verify-jwt"
  },
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "keywords": [
    "well-being",
    "survey",
    "hrd",
    "supabase",
    "vercel"
  ],
  "author": "NIDA Well-being Project",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "dotenv": "^16.6.1",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
