            { "id_prefix": "leave", "label": "จำนวนที่ลาออก/โอนย้าย (คน)",     "type": "number" },
            { "id_prefix": "rate",  "label": "อัตราการลาออก/โอนย้าย (%)",      "type": "computed", "formula": "(leave / ((begin + end) / 2)) * 100" }
          ]
        }
      ]
