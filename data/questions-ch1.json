            {
              "subsection_label": "ระดับชำนาญการ (K)",
              "fields": [
                { "id": "pos_k1", "label": "K1", "type": "number", "required": false, "min": 0 },
                { "id": "pos_k2", "label": "K2", "type": "number", "required": false, "min": 0 },
                { "id": "pos_k3", "label": "K3", "type": "number", "required": false, "min": 0 },
                { "id": "pos_k4", "label": "K4", "type": "number", "required": false, "min": 0 },
                { "id": "pos_k5", "label": "K5", "type": "number", "required": false, "min": 0 }
              ]
            },
            {
              "subsection_label": "ระดับบริหาร (M)",
              "fields": [
                { "id": "pos_m1", "label": "M1", "type": "number", "required": false, "min": 0 },
                { "id": "pos_m2", "label": "M2", "type": "number", "required": false, "min": 0 }
              ]
            },
            {
              "subsection_label": "ระดับสูง (S)",
              "fields": [
                { "id": "pos_s1", "label": "S1", "type": "number", "required": false, "min": 0 },
                { "id": "pos_s2", "label": "S2", "type": "number", "required": false, "min": 0 }
              ]
            }
          ]
        },
        {
          "section_id": "turnover",
          "title": "อัตราการลาออกและโอนย้าย (ย้อนหลัง 5 ปี)",
          "description": "กรอกจำนวนบุคลากรต้นปี ปลายปี และจำนวนที่ลาออก/โอนย้ายในแต่ละปี ระบบจะคำนวณอัตราให้อัตโนมัติ",
