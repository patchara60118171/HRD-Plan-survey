              "label_en": "Organizational Structure",
              "type": "textarea",
              "required": false,
              "placeholder": "อธิบายโครงสร้างองค์กรและสายการบังคับบัญชา",
              "has_file_upload": true,
              "file_field_prefix": "org_structure",
              "file_label": "เอกสารโครงสร้างองค์กร (PDF)"
            },
            {
              "id": "total_staff",
              "label": "จำนวนบุคลากรทั้งหมด (คน)",
