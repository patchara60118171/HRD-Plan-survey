            { "id": "service_21_25",  "label": "21–25 ปี",         "type": "number", "required": false, "min": 0 },
            { "id": "service_26_30",  "label": "26–30 ปี",         "type": "number", "required": false, "min": 0 },
            { "id": "service_over30", "label": "มากกว่า 30 ปี",   "type": "number", "required": false, "min": 0 }
