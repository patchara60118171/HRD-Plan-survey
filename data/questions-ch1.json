            { "id": "type_official",  "label": "ข้าราชการ",            "type": "number", "required": false, "min": 0 },
            { "id": "type_employee",  "label": "พนักงานราชการ",        "type": "number", "required": false, "min": 0 },
            { "id": "type_contract",  "label": "ลูกจ้าง/สัญญาจ้าง",   "type": "number", "required": false, "min": 0 },
            { "id": "type_other",     "label": "อื่นๆ",                 "type": "number", "required": false, "min": 0 }
          ]
        },
        {
          "section_id": "age_distribution",
          "title": "การกระจายตัวตามช่วงอายุ",
          "description": "จำนวนบุคลากรแบ่งตามช่วงอายุ",
          "fields": [
            { "id": "age_u30",   "label": "ต่ำกว่า 30 ปี", "type": "number", "required": false, "min": 0 },
