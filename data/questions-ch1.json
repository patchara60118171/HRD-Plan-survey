            { "id": "engagement_score_2565", "label": "คะแนน Engagement ปี 2565", "type": "number", "required": false, "min": 0, "step": 0.01 },
            { "id": "engagement_score_2564", "label": "คะแนน Engagement ปี 2564", "type": "number", "required": false, "min": 0, "step": 0.01 },
            {
              "id": "engagement_low_areas",
              "label": "มิติ/ด้านที่คะแนนต่ำ",
              "type": "textarea",
              "required": false,
              "placeholder": "ระบุมิติหรือด้านที่บุคลากรมีคะแนน Engagement ต่ำที่สุด"
