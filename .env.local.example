# =============================================
# Supabase Configuration - สำหรับ Admin Access
# คัดลอกไฟล์นี้เป็น .env.local และใส่ค่าจริง
# =============================================

# Supabase Project URL
# หาได้จาก: https://app.supabase.com/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co

# Supabase Anon Key (Public)
# ใช้สำหรับ client-side - ปลอดภัยที่จะแชร์
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6...

# Supabase Service Role Key (Secret) ⚠️ KEEP SECRET!
# ใช้สำหรับ admin access - ห้ามแชร์หรือ commit ลง Git!
# หาได้จาก: https://app.supabase.com/project/YOUR_PROJECT/settings/api
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Database Direct Connection (Optional)
# หาได้จาก: https://app.supabase.com/project/YOUR_PROJECT/settings/database
# แทน [YOUR-PASSWORD] ด้วย database password ของคุณ
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxxx.supabase.co:5432/postgres

# Project Reference ID
# หาได้จาก URL: https://app.supabase.com/project/YOUR_PROJECT_REF
SUPABASE_PROJECT_REF=xxxxxxxxxxxxx

# Supabase Access Token (สำหรับ CLI)
# สร้างได้จาก: https://app.supabase.com/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================
# Optional: Analytics & Monitoring
# =============================================

# Google Analytics 4 Measurement ID
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry DSN (Error Tracking)
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# =============================================
# Google Sheets / Google Drive Sync
# =============================================

# Google Apps Script Web App URL
GOOGLE_SYNC_WEBHOOK_URL=https://script.google.com/macros/s/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx/exec

# Shared secret used by Supabase/Node sync workers and Google Apps Script
GOOGLE_SYNC_SHARED_SECRET=replace_with_a_long_random_secret

# Optional but recommended: Bearer token required to invoke Supabase google-sync function
# If set, callers must send: Authorization: Bearer <GOOGLE_SYNC_FUNCTION_TOKEN>
GOOGLE_SYNC_FUNCTION_TOKEN=replace_with_a_second_long_random_secret

# Max rows per sync batch
GOOGLE_SYNC_BATCH_SIZE=10

# =============================================
# Development Settings
# =============================================

# Environment
NODE_ENV=development

# Port for local development
PORT=3000
