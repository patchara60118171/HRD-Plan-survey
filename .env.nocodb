# NocoDB Configuration for Well-being Survey
# Copy your DATABASE_URL from .env.local and add admin credentials

# Your Local Supabase PostgreSQL connection
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# NocoDB Admin credentials (change these!)
NC_ADMIN_EMAIL=admin@wellbeing.local
NC_ADMIN_PASSWORD=admin123

# NocoDB JWT Secret (change this in production!)
NC_AUTH_JWT_SECRET=wellbeing-nocodb-secret-change-in-production
