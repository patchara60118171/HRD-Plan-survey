{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static Dev Server (serve)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", ".", "--no-clipboard"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "NocoDB Admin (Docker)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "-d"],
      "port": 8080
    },
    {
      "name": "Watch Questions Sync",
      "runtimeExecutable": "node",
      "runtimeArgs": ["scripts/wellbeing/watch-schema.js"],
      "port": 0
    }
  ]
}
