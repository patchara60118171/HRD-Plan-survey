# Well-being Survey - Environment Configuration
# Copy this file to `.env.local` (gitignored) and fill in your actual values.
# Audit L5: single source — merged from the former .env.local.example (deleted).

# ========================================
# Supabase Configuration
# ========================================
# Dashboard: https://app.supabase.com/project/YOUR_PROJECT/settings/api

# Public URL + anon key (safe to expose to the browser)
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service role key — SERVER ONLY, NEVER commit or ship to the browser
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Project ref + CLI access token (for `supabase` CLI / migrations)
SUPABASE_PROJECT_REF=xxxxxxxxxxxxx
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Direct Postgres connection (optional — for pg_dump / psql)
# Dashboard: https://app.supabase.com/project/YOUR_PROJECT/settings/database
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxxx.supabase.co:5432/postgres

# ========================================
# Google Apps Script / Sheets Sync
# ========================================
# Public Apps Script webhook URL — consumed by the client as a backup sink
GOOGLE_SCRIPT_URL=your_google_script_url_here

# Server-to-server sync (Supabase Edge Function ↔ Apps Script)
GOOGLE_SYNC_WEBHOOK_URL=your_google_apps_script_webhook_url_here
GOOGLE_SYNC_SHARED_SECRET=replace_with_a_long_random_secret
GOOGLE_SYNC_FUNCTION_TOKEN=replace_with_a_second_long_random_secret
GOOGLE_SYNC_BATCH_SIZE=10

# Optional: Google OAuth client (only if the admin portal uses Google sign-in)
GOOGLE_CLIENT_ID=your_google_client_id_here

# ========================================
# Application Configuration
# ========================================
APP_NAME=Well-being Survey
APP_VERSION=1.0.0
APP_ENVIRONMENT=development

# ========================================
# Security Configuration
# ========================================
# Admin password (should be hashed in production)
ADMIN_PASSWORD_HASH=your_hashed_admin_password_here
JWT_SECRET=your_jwt_secret_key_here

# ========================================
# Feature Flags
# ========================================
ENABLE_ANALYTICS=true
ENABLE_EXPORT=true
ENABLE_INTEGRATIONS=true
ENABLE_MULTI_LANGUAGE=true

# ========================================
# API Configuration
# ========================================
API_BASE_URL=http://localhost:3000/api
API_TIMEOUT=30000

# ========================================
# Development Only
# ========================================
DEBUG_MODE=true
LOG_LEVEL=info
